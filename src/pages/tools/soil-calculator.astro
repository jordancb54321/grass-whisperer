---
import BaseLayout from '../../layouts/BaseLayout.astro';

const description = 'Estimate how many kilograms of screened topsoil are needed to level an uneven UK lawn using its dimensions, high and low survey readings and surface profile.';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Lawn levelling soil calculator',
  description,
  url: 'https://grasswhisperer.uk/tools/soil-calculator/',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'GBP' },
};
---
<BaseLayout title="Lawn levelling soil calculator" {description} {structuredData}>
  <header class="calculator-hero">
    <div class="container calculator-hero-grid">
      <div>
        <span class="eyebrow">Free lawn tool</span>
        <h1>How much soil will level your lawn?</h1>
      </div>
      <div>
        <p>Enter the lawn size, two level readings and how uneven the surface is. The calculator gives a planning estimate in kilograms, cubic metres and bags.</p>
        <p class="calculator-caveat">Use this for screened topsoil filling hollows—not excavation, turf, sand or drainage aggregate.</p>
      </div>
    </div>
  </header>

  <section class="calculator-section" aria-labelledby="calculator-heading">
    <div class="container calculator-grid">
      <form class="soil-form" id="soil-calculator">
        <div class="form-heading">
          <span class="eyebrow">Your measurements</span>
          <h2 id="calculator-heading">Build the estimate.</h2>
        </div>

        <fieldset>
          <legend><span>01</span> Lawn size</legend>
          <div class="input-pair">
            <label>
              <span>Lawn length</span>
              <span class="input-wrap"><input name="length" type="number" min="0.1" max="1000" step="0.1" inputmode="decimal" required /><b>m</b></span>
            </label>
            <label>
              <span>Lawn width</span>
              <span class="input-wrap"><input name="width" type="number" min="0.1" max="1000" step="0.1" inputmode="decimal" required /><b>m</b></span>
            </label>
          </div>
        </fieldset>

        <fieldset>
          <legend><span>02</span> Level readings</legend>
          <p class="field-help">Measure vertically from the same level string or laser line down to the ground. Only the difference between the two readings is used.</p>
          <div class="input-pair">
            <label>
              <span>Reading at lowest ground</span>
              <span class="input-wrap"><input name="lowReading" type="number" min="0" max="200" step="0.1" inputmode="decimal" required /><b>cm</b></span>
            </label>
            <label>
              <span>Reading at highest ground</span>
              <span class="input-wrap"><input name="highReading" type="number" min="0" max="200" step="0.1" inputmode="decimal" required /><b>cm</b></span>
            </label>
          </div>
        </fieldset>

        <fieldset>
          <legend><span>03</span> How uneven is it?</legend>
          <div class="unevenness-options">
            <label><input type="radio" name="unevenness" value="slight" required /><span><strong>Slight ripples</strong><small>Small isolated dips; most of the lawn is close to level.</small></span></label>
            <label><input type="radio" name="unevenness" value="moderate" checked /><span><strong>Typical hollows</strong><small>A mixed surface with several noticeable low areas.</small></span></label>
            <label><input type="radio" name="unevenness" value="severe" /><span><strong>Very uneven</strong><small>Broad hollows or much of the lawn sits below the high points.</small></span></label>
          </div>
        </fieldset>

        <p class="form-error" id="calculator-error" role="alert" hidden></p>
        <button class="button calculator-submit" type="submit">Calculate soil estimate</button>
      </form>

      <aside class="calculator-result" id="calculator-result" aria-live="polite" aria-atomic="true">
        <div class="result-placeholder" data-placeholder>
          <span class="eyebrow">Estimate output</span>
          <h2>Your result will appear here.</h2>
          <p>Take the measurements from one consistent level line, then choose the description that best matches the whole surface.</p>
        </div>
        <div data-result hidden>
          <span class="eyebrow">Estimated soil to order</span>
          <p class="result-total"><strong data-kilograms>0</strong><span>kg</span></p>
          <p class="result-lede">screened topsoil, including a 10% allowance for settlement and handling.</p>
          <dl class="result-stats">
            <div><dt>Volume to order</dt><dd><span data-volume>0</span> m³</dd></div>
            <div><dt>800 kg bulk bags</dt><dd data-bulk-bags>0</dd></div>
            <div><dt>25 kg small bags</dt><dd data-small-bags>0</dd></div>
          </dl>
          <div class="result-range">
            <span>Planning range</span>
            <strong><span data-range-low>0</span>–<span data-range-high>0</span> kg</strong>
            <p>Soil moisture and supplier density vary, so use the range when comparing quotes.</p>
          </div>
          <ul class="result-assumptions">
            <li><span>Measured area</span><strong><span data-area>0</span> m²</strong></li>
            <li><span>High-to-low difference</span><strong><span data-difference>0</span> cm</strong></li>
            <li><span>Modelled average fill</span><strong><span data-depth>0</span> cm</strong></li>
          </ul>
          <a class="text-link" href="/guides/levelling-a-lawn/">Read the levelling guide</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="calculator-method" aria-labelledby="measure-heading">
    <div class="container">
      <div class="section-head compact">
        <div><span class="eyebrow">Measure once, estimate better</span><h2 id="measure-heading">How to take the readings.</h2></div>
        <p>The figures do not need to be heights above sea level. They only need to come from the same horizontal reference.</p>
      </div>
      <ol class="measure-steps">
        <li><span>01</span><div><h3>Set a level reference</h3><p>Stretch a tight string between level pegs or use a rotating laser. Keep the reference above the highest point.</p></div></li>
        <li><span>02</span><div><h3>Find both extremes</h3><p>Measure from the reference down to the lowest and highest ground. A lower patch normally gives the larger reading.</p></div></li>
        <li><span>03</span><div><h3>Judge the whole surface</h3><p>Choose slight, typical or very uneven based on how much of the lawn needs filling—not just the single deepest dip.</p></div></li>
      </ol>
    </div>
  </section>

  <section class="calculator-notes">
    <div class="container calculator-notes-grid">
      <div><span class="eyebrow">Before ordering</span><h2>An estimate, not a ground survey.</h2></div>
      <div>
        <p>The model treats the lawn as an irregular surface between your two readings. It uses 25%, 40% or 55% of the full height difference as the average fill depth, depending on the unevenness choice.</p>
        <ul>
          <li>Central weight uses 1,500 kg per cubic metre for screened topsoil.</li>
          <li>The order figure includes 10% for settlement, spillage and small measuring errors.</li>
          <li>High spots cut down and reused on site can reduce the amount you need to buy.</li>
          <li>Deep hollows, active settlement or drainage failure need investigation before adding soil.</li>
        </ul>
      </div>
    </div>
  </section>

  <script>
    import { estimateLevellingSoil } from '../../lib/soil-calculator.mjs';

    const form = document.querySelector('#soil-calculator');
    const resultPanel = document.querySelector('#calculator-result');
    const errorPanel = document.querySelector('#calculator-error');
    const formatNumber = new Intl.NumberFormat('en-GB');
    const formatWeight = (value: number) => formatNumber.format(Math.round(value / 10) * 10);

    const setText = (selector: string, value: string | number) => {
      const element = resultPanel?.querySelector(selector);
      if (element) element.textContent = String(value);
    };

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!(form instanceof HTMLFormElement) || !form.reportValidity()) return;

      const data = new FormData(form);
      try {
        const estimate = estimateLevellingSoil({
          lengthMetres: Number(data.get('length')),
          widthMetres: Number(data.get('width')),
          lowReadingCm: Number(data.get('lowReading')),
          highReadingCm: Number(data.get('highReading')),
          unevenness: String(data.get('unevenness')),
        });

        setText('[data-kilograms]', formatWeight(estimate.estimatedKilograms));
        setText('[data-volume]', estimate.orderVolumeCubicMetres.toFixed(2));
        setText('[data-bulk-bags]', estimate.bulkBags);
        setText('[data-small-bags]', estimate.smallBags);
        setText('[data-range-low]', formatWeight(estimate.planningLowKilograms));
        setText('[data-range-high]', formatWeight(estimate.planningHighKilograms));
        setText('[data-area]', estimate.areaSquareMetres);
        setText('[data-difference]', estimate.levelDifferenceCm);
        setText('[data-depth]', estimate.averageFillDepthCm);

        resultPanel?.querySelector('[data-placeholder]')?.setAttribute('hidden', '');
        resultPanel?.querySelector('[data-result]')?.removeAttribute('hidden');
        if (errorPanel instanceof HTMLElement) errorPanel.hidden = true;
      } catch (error) {
        if (errorPanel instanceof HTMLElement) {
          errorPanel.textContent = error instanceof Error ? error.message : 'Check the measurements and try again.';
          errorPanel.hidden = false;
        }
      }
    });
  </script>
</BaseLayout>
