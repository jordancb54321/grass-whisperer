---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from '../components/GuideCard.astro';
import { guides } from '../data/guides';
const description = 'Practical, independent lawn-care guidance for UK gardens: grass seed, fertiliser, watering, levelling, mowing and seasonal maintenance.';
const structuredData = [{ '@context':'https://schema.org','@type':'WebSite', name:'Grass Whisperer', url:'https://grasswhisperer.uk/', description }, { '@context':'https://schema.org','@type':'Organization', name:'Grass Whisperer', url:'https://grasswhisperer.uk/', logo:'https://grasswhisperer.uk/favicon.svg' }];
---
<BaseLayout title="Practical UK Lawn-Care Guides" {description} {structuredData}>
  <section class="hero">
    <div class="hero-copy"><span class="eyebrow">Independent UK lawn-care guides</span><h1>Read your lawn.<br/>Grow it better.</h1><p class="lede">Clear, seasonal advice for healthier grass—from choosing seed and feeding responsibly to watering deeply and fixing a bumpy surface.</p><div class="hero-actions"><a class="button" href="#guides">Explore the guides</a><a class="button secondary" href="/lawn-care-calendar/">What to do this month</a></div></div>
    <div class="hero-art" role="img" aria-label="Illustrated cross-section of healthy grass and soil"><div class="hero-sky"></div><div class="hero-turf"></div><div class="soil-cut"><span></span><span></span><span></span></div></div>
  </section>
  <section class="intro-strip"><div class="container"><span class="eyebrow">The short version</span><p>A great lawn is mostly observation, consistent mowing and healthy soil—not a shed full of quick fixes.</p></div></section>
  <section class="guide-index" id="guides"><div class="container"><div class="section-head"><div><span class="eyebrow">The lawn library</span><h2>Start with what you can see.</h2></div><p>Each guide explains what to look for, why it matters and the least complicated way to put it right. Written for the British climate and ordinary home lawns.</p></div><div class="guide-grid">{guides.map((guide,index)=><GuideCard {guide} {index}/>)}</div></div></section>
  <section class="season"><div class="container season-grid"><div><span class="eyebrow">Right job. Right moment.</span><h2>Let the season set the pace.</h2><p>Grass responds to soil temperature, moisture and daylight—not dates printed on a bag. Use the calendar as a prompt, then check conditions outside.</p><a class="button" href="/lawn-care-calendar/">Open the annual calendar</a></div><div class="season-list"><div class="season-item"><span>01</span><div><h3>Spring — restart gently</h3><p>Resume mowing, repair winter damage and feed only after active growth begins.</p></div></div><div class="season-item"><span>02</span><div><h3>Summer — protect resilience</h3><p>Mow higher, water only when needed and accept temporary dormancy.</p></div></div><div class="season-item"><span>03</span><div><h3>Autumn — renovate</h3><p>Scarify, aerate, overseed and use warm soil to establish new roots.</p></div></div><div class="season-item"><span>04</span><div><h3>Winter — keep off the frost</h3><p>Clear leaves, avoid saturated ground and service your mower.</p></div></div></div></div></section>
  <section class="principle"><div class="container"><span class="eyebrow">The Grass Whisperer principle</span><blockquote>Do not treat a symptom until you understand the <em>conditions beneath it.</em></blockquote><p>Moss, weeds, pale grass and puddles are clues. Improve the cause—light, soil, drainage, compaction or mowing—and the lawn becomes easier to manage.</p></div></section>
</BaseLayout>
