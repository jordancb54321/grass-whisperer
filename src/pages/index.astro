---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from '../components/GuideCard.astro';
import { guides } from '../data/guides';
import { monthNames, problemRoutes } from '../data/navigation';

const description = 'Independent lawn-care guidance for UK gardens, covering grass types, seed, fertiliser, watering, levelling, mowing, aeration and seasonal maintenance.';
const structuredData = [
  { '@context':'https://schema.org', '@type':'WebSite', name:'Grass Whisperer', url:'https://grasswhisperer.uk/', description },
  { '@context':'https://schema.org', '@type':'Organization', name:'Grass Whisperer', url:'https://grasswhisperer.uk/', logo:'https://grasswhisperer.uk/favicon.svg' }
];
const fieldNotes = guides.filter(({ slug }) => ['grass-seed', 'watering', 'levelling-a-lawn'].includes(slug));
---
<BaseLayout title="Independent UK lawn-care guides" {description} {structuredData}>
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow">Independent UK lawn field guide</span>
      <h1>A better lawn starts with a closer look.</h1>
      <p class="lede">Understand the grass, soil and weather before you reach for another treatment.</p>
      <div class="hero-actions">
        <a class="button" href="#diagnose">Find your starting point</a>
        <a class="button secondary" href="/lawn-care-calendar/">See the yearly jobs</a>
      </div>
    </div>
    <figure class="hero-photo">
      <img src="/images/hero.webp" srcset="/images/hero-640.webp 640w, /images/hero.webp 1000w" sizes="(max-width: 900px) 100vw, 55vw" alt="Curving path through a shaded lawn at the Gibberd Garden in Essex" width="1000" height="723" fetchpriority="high" />
      <figcaption>Gibberd Garden, Essex <a href="/photo-credits/">Photo: Acabashi</a></figcaption>
    </figure>
  </section>

  <section class="intro-strip" aria-label="Grass Whisperer principle">
    <div class="container">
      <span class="eyebrow">Observe first. Treat second.</span>
      <p>If the grass looks wrong, check the soil, light and mowing before adding another product.</p>
    </div>
  </section>

  <section class="trust-band" aria-label="Editorial approach">
    <div class="container trust-grid">
      <div><span>01</span><strong>Written for UK conditions</strong><p>Weather and soil decide the timing, not a rigid date.</p></div>
      <div><span>02</span><strong>Independent guidance</strong><p>No paid placements, affiliate rankings or miracle claims.</p></div>
      <div><span>03</span><strong>Useful detail</strong><p>Clear rates, limitations and reasons behind each method.</p></div>
    </div>
  </section>

  <section class="problem-finder" id="diagnose">
    <div class="container">
      <div class="section-head compact">
        <div><span class="eyebrow">Start with what you can see</span><h2>What is your lawn doing?</h2></div>
        <p>Choose the closest symptom. The guide will help you check the cause before deciding what to do.</p>
      </div>
      <div class="problem-list">
        {problemRoutes.map((route, index) =>
          <a href={route.href}>
            <span class="problem-number">{String(index + 1).padStart(2, '0')}</span>
            <div><h3>{route.symptom}</h3><p>{route.detail}</p></div>
            <strong>{route.action}<span aria-hidden="true"> ↗</span></strong>
          </a>
        )}
      </div>
    </div>
  </section>

  <section class="guide-index" id="guides">
    <div class="container">
      <div class="section-head">
        <div><span class="eyebrow">The lawn library</span><h2>Learn the job properly.</h2></div>
        <div class="section-copy"><p>Seven practical guides explain the method, the timing and the point at which a different problem needs attention.</p><a class="text-link" href="/guides/">Browse the complete library</a></div>
      </div>
      <div class="guide-list">{guides.map((guide,index)=><GuideCard {guide} {index}/>)}</div>
    </div>
  </section>

  <section class="field-notes">
    <div class="container">
      <div class="field-notes-head"><span class="eyebrow">From the field notes</span><p>Three jobs where the detail matters more than the product.</p></div>
      <div class="photo-stories">
        {fieldNotes.map((guide, index) =>
          <a class:list={['photo-story', { wide: index === 0 }]} href={`/guides/${guide.slug}/`}>
            <img src={guide.image} alt={guide.imageAlt} width={guide.imageWidth} height={guide.imageHeight} loading="lazy" />
            <div><span>{guide.readTime}</span><h3>{guide.title}</h3><p>{guide.intro}</p></div>
          </a>
        )}
      </div>
    </div>
  </section>

  <section class="season">
    <div class="container season-grid">
      <div><span class="eyebrow">Work with the weather</span><h2>The date is only a hint.</h2><p>A warm, damp September may be ideal for seed. A dry one is not. Check the soil and forecast before following the calendar.</p><a class="button" href="/lawn-care-calendar/">Open the care calendar</a></div>
      <div>
        <nav class="month-rail" aria-label="Jump to a month in the lawn calendar">
          {monthNames.map((month) => <a href={`/lawn-care-calendar/#${month.toLowerCase()}`}>{month.slice(0,3)}</a>)}
        </nav>
        <div class="season-list">
          <div class="season-item"><span>01</span><div><h3>Spring</h3><p>Restart mowing gently. Repair winter wear once growth is moving.</p></div></div>
          <div class="season-item"><span>02</span><div><h3>Summer</h3><p>Cut higher in dry weather and let established turf rest if water is short.</p></div></div>
          <div class="season-item"><span>03</span><div><h3>Autumn</h3><p>Warm soil makes this the best window for seed, aeration and repairs.</p></div></div>
          <div class="season-item"><span>04</span><div><h3>Winter</h3><p>Clear leaves and keep heavy traffic off wet or frozen ground.</p></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="standards">
    <div class="container standards-grid">
      <div><span class="eyebrow">How the advice is written</span><h2>No sales pitch hiding inside the guide.</h2></div>
      <div class="standards-copy">
        <p>Grass Whisperer explains what a material or method can do, where it falls short, and what to inspect first. Product labels and local restrictions always take priority.</p>
        <ul>
          <li><span>Evidence over slogans</span>Rates and timings are specific enough to use.</li>
          <li><span>Ordinary gardens</span>The advice allows for shade, children, pets and imperfect soil.</li>
          <li><span>Visible limits</span>Drainage failure and subsidence are not disguised as lawn-care jobs.</li>
        </ul>
        <a class="text-link" href="/about/">Read the editorial approach</a>
      </div>
    </div>
  </section>
</BaseLayout>
